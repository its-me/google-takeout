#!/bin/bash
set -eo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

info()    { echo -e "${GREEN}[INFO]${NC} $1"; }
warning() { echo -e "${YELLOW}[WARNING]${NC} $1"; }
error()   { echo -e "${RED}[ERROR]${NC} $1"; }

command -v xz &>/dev/null || { error "xz is not installed. Install: sudo apt install xz-utils"; exit 1; }

OUTPUT_BASE="${1:-Takeout}"
EXTRACT_DIR="./tmp"

info "Searching for Google Takeout archives in current directory"
mapfile -t ARCHIVES < <(find . -maxdepth 1 -type f \( -name "takeout-*.zip" -o -name "takeout-*.tgz" -o -name "takeout-*.tar.gz" \) | sort)
[[ ${#ARCHIVES[@]} -eq 0 ]] && { error "No archives found. Looking for: takeout-*.zip, takeout-*.tgz, takeout-*.tar.gz"; exit 1; }
info "Found ${#ARCHIVES[@]} archive(s)"

if [[ "$(basename "${ARCHIVES[0]}")" =~ takeout-([0-9]{4})([0-9]{2})([0-9]{2}) ]]; then
    TAKEOUT_DATE="${BASH_REMATCH[1]}-${BASH_REMATCH[2]}-${BASH_REMATCH[3]}"
elif [[ "$(basename "${ARCHIVES[0]}")" =~ takeout-([0-9]{4}-[0-9]{2}-[0-9]{2}) ]]; then
    TAKEOUT_DATE="${BASH_REMATCH[1]}"
else
    warning "Could not extract date from filename, using current date"
    TAKEOUT_DATE=$(date +%Y-%m-%d)
fi

MERGED_DIR="./${OUTPUT_BASE}-${TAKEOUT_DATE}"
ARCHIVE_PATH="$PWD/${OUTPUT_BASE}-${TAKEOUT_DATE}.tar.xz"
mkdir -p "$MERGED_DIR"

for archive in "${ARCHIVES[@]}"; do
    info "Extracting: $(basename "$archive")"
    mkdir -p "$EXTRACT_DIR"
    case "$archive" in
        *.zip)          unzip -q -o "$archive" -d "$EXTRACT_DIR" || { error "Failed to extract $archive"; exit 1; } ;;
        *.tgz|*.tar.gz) tar -xzf "$archive" -C "$EXTRACT_DIR"   || { error "Failed to extract $archive"; exit 1; } ;;
    esac
    src="$EXTRACT_DIR/Takeout"
    [[ -d "$src" ]] || src="$EXTRACT_DIR"
    rsync -a "$src/" "$MERGED_DIR/"
    rm -rf "$EXTRACT_DIR"
done

info "Creating archive: $ARCHIVE_PATH"
XZ_OPT="-9e -T0" nice -n 19 tar -cJf "$ARCHIVE_PATH" -C "$MERGED_DIR" . || { error "Failed to create archive"; exit 1; }

echo ""
info "=== COMPLETION SUMMARY ==="
info "Merged archives : ${#ARCHIVES[@]}"
info "Total files     : $(find "$MERGED_DIR" -type f | wc -l)"
info "Takeout date    : $TAKEOUT_DATE"
info "Output file     : $ARCHIVE_PATH ($(du -h "$ARCHIVE_PATH" | cut -f1))"
