#!/usr/bin/env bash
set -euo pipefail

DRY_RUN=false
TARGET=both

while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run|-n) DRY_RUN=true; shift ;;
    b2|drive)     TARGET="$1"; shift ;;
    *) echo "Usage: takeout-retention [--dry-run|-n] [b2|drive]" >&2; exit 1 ;;
  esac
done

TAKEOUT_RCLONE_B2_REMOTE_NAME="${TAKEOUT_RCLONE_B2_REMOTE_NAME:-}"
TAKEOUT_RCLONE_B2_REMOTE_DIR="${TAKEOUT_RCLONE_B2_REMOTE_DIR:-}"
TAKEOUT_RCLONE_DRIVE_REMOTE_NAME="${TAKEOUT_RCLONE_DRIVE_REMOTE_NAME:-}"
TAKEOUT_RCLONE_DRIVE_REMOTE_DIR="${TAKEOUT_RCLONE_DRIVE_REMOTE_DIR:-}"
TAKEOUT_RETENTION_KEEP_LAST="${TAKEOUT_RETENTION_KEEP_LAST:-10}"

if [[ "$TARGET" == "b2" || "$TARGET" == "both" ]]; then
  [[ -z "$TAKEOUT_RCLONE_B2_REMOTE_NAME" ]] && { echo "Error: TAKEOUT_RCLONE_B2_REMOTE_NAME is not set" >&2; exit 1; }
  [[ -z "$TAKEOUT_RCLONE_B2_REMOTE_DIR"  ]] && { echo "Error: TAKEOUT_RCLONE_B2_REMOTE_DIR is not set" >&2;  exit 1; }
fi
if [[ "$TARGET" == "drive" || "$TARGET" == "both" ]]; then
  [[ -z "$TAKEOUT_RCLONE_DRIVE_REMOTE_NAME" ]] && { echo "Error: TAKEOUT_RCLONE_DRIVE_REMOTE_NAME is not set" >&2; exit 1; }
  [[ -z "$TAKEOUT_RCLONE_DRIVE_REMOTE_DIR"  ]] && { echo "Error: TAKEOUT_RCLONE_DRIVE_REMOTE_DIR is not set" >&2;  exit 1; }
fi

# Retention rules:
#   1. Always keep files dated on the 1st or 16th of any month
#   2. Always keep the most recent $TAKEOUT_RETENTION_KEEP_LAST files (rules 1+2 overlap — 1st/16th count toward the 10)
apply_retention() {
  local remote_name="$1"
  local remote_dir="${2%/}"
  local remote="${remote_name}:${remote_dir}"

  echo "[INFO] Processing $remote"

  mapfile -t files < <(rclone lsf "$remote" --files-only --max-depth 1 --include "*.tar.xz.age" | sort -r)

  if [[ ${#files[@]} -eq 0 ]]; then
    echo "[INFO] No backups found"
    return
  fi

  echo "[INFO] Found ${#files[@]} backup(s)"

  local rank=0
  local deleted=0
  for file in "${files[@]}"; do
    rank=$((rank + 1))

    date_str=$(echo "$file" | grep -oE '[0-9]{4}-[0-9]{2}-[0-9]{2}' | head -1)
    if [[ -z "$date_str" ]]; then
      echo "[WARN]   $file — cannot parse date, skipping"
      continue
    fi

    day="${date_str##*-}"
    keep=false
    reasons=()

    [[ $rank -le $TAKEOUT_RETENTION_KEEP_LAST ]] && { keep=true; reasons+=("top $TAKEOUT_RETENTION_KEEP_LAST"); }
    [[ "$day" == "01" || "$day" == "16" ]] && { keep=true; reasons+=("day-of-month $day"); }

    if $keep; then
      reason=$(IFS=', '; echo "${reasons[*]}")
      echo "[KEEP]   $file  ($reason)"
    else
      deleted=$((deleted + 1))
      if $DRY_RUN; then
        echo "[DELETE] $file  (would delete)"
      else
        echo "[DELETE] $file"
        rclone deletefile "${remote}/${file}"
      fi
    fi
  done

  if $DRY_RUN; then
    echo "[INFO] Dry run complete — $deleted file(s) would be deleted"
  else
    echo "[INFO] Done — $deleted file(s) deleted"
  fi
}

$DRY_RUN && echo "[INFO] Dry run — no files will be deleted"

if [[ "$TARGET" == "b2" || "$TARGET" == "both" ]]; then
  echo ""
  apply_retention "$TAKEOUT_RCLONE_B2_REMOTE_NAME" "$TAKEOUT_RCLONE_B2_REMOTE_DIR"
fi
if [[ "$TARGET" == "drive" || "$TARGET" == "both" ]]; then
  echo ""
  apply_retention "$TAKEOUT_RCLONE_DRIVE_REMOTE_NAME" "$TAKEOUT_RCLONE_DRIVE_REMOTE_DIR"
fi
